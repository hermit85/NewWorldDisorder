# ─── Supabase Configuration ───
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# Leave empty to run in mock/demo mode (no real auth or persistence)

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Sentry Configuration ───
# Runtime DSN is public and safe for Expo public env usage.
# Build upload tokens must stay in local/CI secrets, never in committed files.
EXPO_PUBLIC_SENTRY_DSN=https://public-key@o0.ingest.sentry.io/project-id
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug
SENTRY_AUTH_TOKEN=sntrys_your-release-upload-token

# ─── Notes ───
# When configured: app uses real Supabase auth, profiles, leaderboard, run persistence
# When empty: app runs in demo mode with mock data (no shared world)
# The .env file is gitignored — never commit real credentials
