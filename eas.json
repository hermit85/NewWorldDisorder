{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "ios": {
        "buildConfiguration": "Release"
      }
    },
    "production": {
      "environment": "production",
      "autoIncrement": true,
      "ios": {
        "buildConfiguration": "Release"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "darek@cybirdconsulting.com",
        "ascAppId": "6761112863",
        "appleTeamId": "TQ83SMV649"
      }
    }
  }
}
